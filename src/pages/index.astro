---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCourseIndex } from "../lib/contentDiscovery.js";
import { siteMetadata } from "../lib/siteMetadata.js";
import { toSitePath } from "../lib/siteUrls.js";

type CourseIndexUnit = {
  slug: string;
  title: string;
  modules: Array<{
    routePath: string;
    title: string;
  }>;
};

const courseIndex = await getCourseIndex();
const units: CourseIndexUnit[] = courseIndex.units;
---

<BaseLayout title={`${siteMetadata.siteTitle} Course Index`}>
  <section class="course-index" aria-labelledby="course-index-title">
    <header class="course-index__header">
      <p class="course-index__eyebrow">{siteMetadata.courseLabel}</p>
      <h1 id="course-index-title">{siteMetadata.siteTitle}</h1>
      <p class="course-index__intro">{siteMetadata.siteDescription}</p>
    </header>

    <div class="course-index__units" aria-label="Course units">
      {
        units.map((unit, unitIndex) => (
          <section class="course-index__unit" aria-labelledby={`${unit.slug}-title`}>
            <div class="course-index__unit-heading">
              <span class="course-index__unit-number" aria-hidden="true">
                {String(unitIndex + 1).padStart(2, "0")}
              </span>
              <h2 id={`${unit.slug}-title`}>{unit.title}</h2>
            </div>

            <ol class="course-index__module-list">
              {unit.modules.map((module) => (
                <li class="course-index__module">
                  <a class="course-index__module-link" href={toSitePath(module.routePath)}>
                    <span class="course-index__module-title">{module.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
